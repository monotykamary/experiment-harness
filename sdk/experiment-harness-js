#!/usr/bin/env bash
# experiment-harness-js — eval JS in the persistent experiment harness.
# Auto-starts the server on first use.
#
# Usage:
#   experiment-harness-js 'await session.init({ cwd: "/path/to/project", config: { name: "optimize tests", metricName: "seconds", direction: "lower", command: "bash autoresearch.sh" } })'
#   experiment-harness-js 'await session.run({ timeoutSeconds: 600 })'
#   experiment-harness-js 'await session.log({ metric: 12.3, status: "keep", description: "pool workers" })'
#   experiment-harness-js 'await session.runAndLog()'
#   experiment-harness-js 'session.status()'
#   experiment-harness-js 'session.results({ last: 10 })'
#
#   experiment-harness-js --status   # is the server running?
#   experiment-harness-js --stop     # gracefully shut it down
#   experiment-harness-js --logs     # tail the server log
#   experiment-harness-js --restart  # stop + start fresh (drops session state)
#   experiment-harness-js --start    # explicit start (no-op if already running)

set -euo pipefail

PORT="${EXPERIMENT_HARNESS_PORT:-9877}"
HOST="127.0.0.1"
URL="http://$HOST:$PORT"

# Resolve server.ts alongside this script, following symlinks.
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SERVER="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/server.ts"

LOG="${EXPERIMENT_HARNESS_LOG:-/tmp/experiment-harness.log}"

# ---------------------------------------------------------------------------
# Bootstrap bun if missing — the experiment server is Bun-native.
# ---------------------------------------------------------------------------

ensure_bun() {
  if command -v bun >/dev/null 2>&1; then return 0; fi
  if [ -x "$HOME/.bun/bin/bun" ]; then
    export PATH="$HOME/.bun/bin:$PATH"
    return 0
  fi
  if [ -n "${EXPERIMENT_HARNESS_SKIP_BUN_INSTALL:-}" ]; then
    echo "experiment-harness-js: bun not found and EXPERIMENT_HARNESS_SKIP_BUN_INSTALL is set." >&2
    echo "  Install manually: curl -fsSL https://bun.sh/install | bash" >&2
    return 1
  fi
  echo "experiment-harness-js: installing bun (one-time, from https://bun.sh/install)..." >&2
  if ! curl -fsSL https://bun.sh/install | bash >&2; then
    echo "experiment-harness-js: bun install failed. Install manually from https://bun.sh" >&2
    return 1
  fi
  export PATH="$HOME/.bun/bin:$PATH"
  command -v bun >/dev/null 2>&1 || {
    echo "experiment-harness-js: bun installed but not found at \$HOME/.bun/bin/bun." >&2
    return 1
  }
}

# ---------------------------------------------------------------------------
# Server lifecycle
# ---------------------------------------------------------------------------

is_up() {
  curl -fsS --max-time 1 "$URL/health" >/dev/null 2>&1
}

start_server() {
  is_up && return 0
  ensure_bun || return 1
  EXPERIMENT_HARNESS_PORT="$PORT" nohup bun "$SERVER" >"$LOG" 2>&1 &
  for _ in $(seq 1 100); do
    sleep 0.1
    is_up && return 0
  done
  echo "experiment-harness-js: server failed to start on $URL (see $LOG)" >&2
  return 1
}

# ---------------------------------------------------------------------------
# Eval
# ---------------------------------------------------------------------------

post_eval() {
  local out status body
  out=$(curl -sS -w '\n___STATUS___%{http_code}' --data-binary "$1" "$URL/eval")
  status="${out##*___STATUS___}"
  body="${out%$'\n'___STATUS___*}"
  if [ "$status" = "200" ]; then
    [ -n "$body" ] && printf '%s\n' "$body"
    return 0
  else
    [ -n "$body" ] && printf '%s\n' "$body" >&2
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

case "${1:-}" in
  --status)
    if is_up; then
      curl -sS "$URL/health"; echo
    else
      echo '{"ok":false,"error":"down"}'
      exit 1
    fi
    ;;
  --start)
    start_server
    curl -sS "$URL/health"; echo
    ;;
  --stop)
    if is_up; then
      curl -s -X POST "$URL/quit" >/dev/null || true
      echo '{"ok":true,"stopped":true}'
    else
      echo '{"ok":true,"stopped":false,"note":"already down"}'
    fi
    ;;
  --restart)
    is_up && curl -s -X POST "$URL/quit" >/dev/null 2>&1 || true
    sleep 0.2
    start_server
    curl -sS "$URL/health"; echo
    ;;
  --logs)
    exec tail -f "$LOG"
    ;;
  --help|-h)
    sed -n '2,/^set -euo/p' "$0" | sed 's/^#//; s/^ //; /^set -euo/d'
    ;;
  "")
    start_server
    code="$(cat)"
    post_eval "$code"
    ;;
  *)
    start_server
    post_eval "$1"
    ;;
esac
